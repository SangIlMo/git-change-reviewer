diff --git a/src/services/payment.ts b/src/services/payment.ts
index 1a2b3c4..5d6e7f8 100644
--- a/src/services/payment.ts
+++ b/src/services/payment.ts
@@ -1,9 +1,13 @@
 import { stripe } from './stripe-client.js';
+import { logger } from '../utils/logger.js';
+import type { PaymentResult } from '../types/payment.js';
 
-export async function chargeCard(amount: number, token: string): Promise<void> {
-  await stripe.charges.create({ amount, currency: 'usd', source: token });
+export async function chargeCard(amount: number, token: string, key: string): Promise<PaymentResult> {
+  logger.info('Initiating charge', { amount, key });
+  const charge = await stripe.charges.create({ amount, currency: 'usd', source: token }, { idempotencyKey: key });
+  return { chargeId: charge.id, status: charge.status };
 }
 
-export async function refund(chargeId: string): Promise<void> {
-  await stripe.refunds.create({ charge: chargeId });
+export async function refund(chargeId: string, reason?: string): Promise<void> {
+  await stripe.refunds.create({ charge: chargeId, reason });
 }
diff --git a/scripts/sync_products.py b/scripts/sync_products.py
index a9b8c7d..e1f2a3b 100644
--- a/scripts/sync_products.py
+++ b/scripts/sync_products.py
@@ -1,8 +1,14 @@
 import requests
+import logging
 from typing import List, Dict
 
-def sync_products(api_url: str, products: List[Dict]) -> None:
-    for product in products:
-        resp = requests.post(f"{api_url}/products", json=product)
-        if resp.status_code != 201:
-            raise RuntimeError(f"Failed to sync: {resp.status_code}")
+logger = logging.getLogger(__name__)
+
+def sync_products(api_url: str, products: List[Dict], batch_size: int = 50) -> int:
+    synced = 0
+    for i in range(0, len(products), batch_size):
+        batch = products[i:i + batch_size]
+        resp = requests.post(f"{api_url}/products/batch", json={"products": batch}, timeout=30)
+        resp.raise_for_status()
+        synced += len(batch)
+    return synced
